#!/bin/bash

set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${SCRIPT_DIR}/btrfssnap_common"

[ "$#" -eq 0 ] || fail "Usage: btrfssnap_snapshoot"

btrfs_root="$(read_configured_root)"
retention_limit="$(read_configured_retention)"
device="$(get_btrfs_device_for_root "${btrfs_root}")"

mnt_tmp="$(mktemp -d /tmp/btrfssnap-root.XXXXXX)"
mounted="0"

cleanup() {
    if [ "${mounted}" = "1" ]; then
        umount "${mnt_tmp}" >/dev/null 2>&1 || true
    fi
    rmdir "${mnt_tmp}" >/dev/null 2>&1 || true
}
trap cleanup EXIT

mount -t btrfs -o subvolid=5 "${device}" "${mnt_tmp}" || fail "Failed to mount top-level BTRFS root."
mounted="1"

source_subvolume="${mnt_tmp}/base"
[ -d "${source_subvolume}" ] || fail "Source subvolume does not exist: ${source_subvolume}"

timestamp="v$(date +%Y%m%d-%H%M)"
target_subvolume="${mnt_tmp}/${timestamp}"

btrfs subvolume snapshot -r "${source_subvolume}" "${target_subvolume}" || fail "Failed to create snapshot."

mapfile -t snapshots < <(
    shopt -s nullglob
    for snap in "${mnt_tmp}"/v[0-9][0-9][0-9][0-9]*; do
        printf '%s\n' "${snap}"
    done | sort
)

count="${#snapshots[@]}"
if [ "${count}" -gt "${retention_limit}" ]; then
    remove_count=$((count - retention_limit))
    for ((i = 0; i < remove_count; i++)); do
        btrfs subvolume delete "${snapshots[$i]}" || fail "Failed to delete old snapshot: ${snapshots[$i]}"
    done
fi

echo "${timestamp}"
